# Markaba — environment variables
# Copy to .env and fill in LOCAL/SANDBOX values only.
# GOLDEN RULE (CLAUDE.md §2.2): no real BVNs, no real bank credentials, no live
# open-banking tokens, no production API keys — ever, in any environment file
# committed to this repo.

# ---- Core ----
NODE_ENV=development
PORT=3000

# Set to "mock" in every environment until OBR/NIFI registration + live credentials
# exist (CLAUDE.md §2.4). "live" is not implemented and will throw on startup.
PROVIDER_MODE=mock

# ---- Database (local Postgres only) ----
DATABASE_URL=postgresql://markaba:markaba@localhost:5432/markaba_dev

# ---- Audit log ----
AUDIT_LOG_ACTOR_SYSTEM=system

# ---- Mock auth (mobile only — admin uses real OAuth, see below) ----
MOCK_AUTH_JWT_SECRET=dev-only-placeholder-change-me

# ---- Admin portal auth (real — Google/Microsoft OAuth via Auth.js) ----
# See docs/decisions/0002-admin-oauth-jwt-sessions.md and packages/admin/README
# (provisioning steps) for how to obtain each of these. Separate database from
# the one above — packages/admin/prisma/schema.prisma, not packages/api's.
# Plain Postgres connection string (Neon) — no platform-specific DB product.
ADMIN_DATABASE_URL=postgresql://markaba:markaba@localhost:5432/markaba_admin_dev
NEXTAUTH_SECRET=dev-only-placeholder-run-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3001
GOOGLE_CLIENT_ID=placeholder-google-oauth-client-id
GOOGLE_CLIENT_SECRET=placeholder-google-oauth-client-secret
MICROSOFT_ENTRA_CLIENT_ID=placeholder-entra-client-id
MICROSOFT_ENTRA_CLIENT_SECRET=placeholder-entra-client-secret
MICROSOFT_ENTRA_TENANT_ID=placeholder-entra-tenant-id
# The one email that gets seeded as the first SuperAdmin invite — solves the
# chicken-and-egg problem of "someone has to be SuperAdmin before anyone can
# invite anyone." Run `npm run prisma:seed --workspace=@markaba/admin` once
# this is set to a real work email.
INITIAL_SUPERADMIN_EMAIL=placeholder@example.com

# ---- WhatsApp Business API (sandbox) ----
WHATSAPP_WEBHOOK_VERIFY_TOKEN=placeholder-verify-token
WHATSAPP_APP_SECRET=placeholder-app-secret
WHATSAPP_ACCESS_TOKEN=placeholder-sandbox-access-token
WHATSAPP_PHONE_NUMBER_ID=placeholder-phone-number-id

# ---- Africa's Talking (USSD/SMS — mock adapter) ----
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=placeholder-sandbox-key

# ---- Smile Identity (KYC — sandbox) ----
SMILE_IDENTITY_PARTNER_ID=placeholder-partner-id
SMILE_IDENTITY_API_KEY=placeholder-sandbox-api-key

# ---- Mono / Okra (Open Banking — mock adapter only) ----
MONO_SECRET_KEY=placeholder-mock-secret-key
OKRA_TOKEN=placeholder-mock-token

# ---- Paystack (Payments — sandbox) ----
PAYSTACK_SECRET_KEY=sk_test_placeholder
PAYSTACK_PUBLIC_KEY=pk_test_placeholder

# ---- Initrack / Tracker NG (GPS telematics — mock adapter only) ----
INITRACK_API_KEY=placeholder-mock-api-key

# ---- DocuSign / Zoho Sign (e-signature — stub only) ----
ESIGNATURE_PROVIDER=stub
DOCUSIGN_INTEGRATION_KEY=placeholder-integration-key
ZOHOSIGN_CLIENT_ID=placeholder-client-id
