{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "noEmit": true,
    // Overrides tsconfig.base.json's declaration:true — this is an app, not
    // a library, and Auth.js v5's complex inferred export types (auth.ts's
    // `auth`, middleware.ts's default export) trip TS2742 ("inferred type
    // cannot be named") when declaration emission is considered, even with
    // noEmit set.
    "declaration": false,
    "incremental": true,
    "isolatedModules": true,
    "allowJs": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
